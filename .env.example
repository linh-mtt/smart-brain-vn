# ==============================================
# SmartMath Kids - Environment Configuration
# ==============================================
# Copy this file to .env and update the values

# PostgreSQL
POSTGRES_USER=smartmath
POSTGRES_PASSWORD=smartmath_dev_pass
POSTGRES_DB=smartmath
POSTGRES_PORT=5432

# DragonflyDB (Redis-compatible)
REDIS_PASSWORD=smartmath_redis_dev
REDIS_PORT=6379

# Backend
BACKEND_PORT=3000
JWT_SECRET=dev_jwt_secret_change_in_production_minimum_32_chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
RUST_LOG=info,smartmath_backend=debug
ENVIRONMENT=development

# Frontend
FRONTEND_PORT=8080
API_BASE_URL=http://localhost:3000/api/v1
WS_URL=ws://localhost:3000/ws
