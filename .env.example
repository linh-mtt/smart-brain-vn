# ==============================================
# SmartMath Kids - Docker Infrastructure Variables
# ==============================================
# This file is used ONLY by Docker Compose for infrastructure services.
# Application config lives in each module's own .env files:
#   - backend/.env   (backend app config)
#   - frontend/.env  (frontend app config)
#
# Copy this file to .env and update as needed:
#   cp .env.example .env

# ─── PostgreSQL ───────────────────────────────
POSTGRES_USER=smartmath
POSTGRES_PASSWORD=smartmath_dev_pass
POSTGRES_DB=smartmath
POSTGRES_PORT=5432

# ─── DragonflyDB (Redis-compatible) ──────────
REDIS_PASSWORD=smartmath_redis_dev
REDIS_PORT=6379

# ─── Service Ports ───────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=8080

# ─── App Environment (passed to backend container) ──
# Values: development | staging | production
APP_ENV=development
