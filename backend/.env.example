# ─── SmartMath Kids — Backend Environment ────────────────
# This file serves as a template for backend configuration.
# Copy to .env and update values for your environment.
#
# Multi-env loading order (highest priority first):
#   .env.[APP_ENV].local  →  .env.[APP_ENV]  →  .env.local  →  .env
#
# APP_ENV values: development | staging | production
# ─────────────────────────────────────────────────────────
APP_ENV=development

# ─── Backend ──────────────────────────────────
DATABASE_URL=postgres://smartmath:smartmath_dev_pass@localhost:5432/smartmath
REDIS_URL=redis://default:smartmath_redis_dev@localhost:6379
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
JWT_SECRET=dev_jwt_secret_change_in_production_minimum_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RUST_LOG=info,smartmath_backend=debug
