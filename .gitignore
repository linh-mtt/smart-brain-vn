# Environment - Multi-env dotenv support
# Each module loads .env files from its own directory only.
# Priority: .env.[mode].local > .env.[mode] > .env.local > .env
#
# Root .env is for Docker Compose infrastructure variables only.
# Local override files (.env.local, .env.*.local) are git-ignored.

# Root (Docker infra)
.env
.env.local
.env.*.local
!.env.example

# Backend module
backend/.env
backend/.env.local
backend/.env.*.local
!backend/.env.example

# Frontend module
frontend/.env
frontend/.env.local
frontend/.env.*.local
!frontend/.env.example

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# macOS
.DS_Store
Thumbs.db

# Rust
backend/target/

# Flutter
frontend/.dart_tool/
frontend/.packages
frontend/build/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/pubspec.lock
frontend/**/*.g.dart
frontend/**/*.freezed.dart

# Logs
*.log
